# Copy this file to .env and fill in real credentials
# Example SMTP configuration for Gmail (use App Password if 2FA enabled)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your_app_password_or_smtp_password
DEFAULT_FROM_EMAIL="BugTracker <your-email@example.com>"

# Optional: override DEBUG in .env for testing
# DEBUG=True
